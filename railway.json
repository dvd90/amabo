{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "pnpm build && pnpm --filter @amabo/web build"
  },
  "deploy": {
    "preDeployCommand": "pnpm --filter @amabo/api db:migrate",
    "startCommand": "pnpm --filter @amabo/api start",
    "healthcheckPath": "/health",
    "healthcheckTimeout": 60,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 5
  }
}
