{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "buildCommand": "cd ../../ && pnpm install --frozen-lockfile && pnpm --filter @amabo/web build"
  },
  "deploy": {
    "startCommand": "pnpm start",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 5
  }
}
