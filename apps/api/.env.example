# apps/api environment (12-factor; never commit real secrets — ARCHITECTURE.md §16)
# Copy to apps/api/.env for local dev; on Railway set these as service Variables.

DATABASE_URL=postgres://user:pass@localhost:5432/amabo
ANTHROPIC_API_KEY=sk-ant-...
PORT=3000

# This API's own public origin (used to build OAuth + magic-link callback URLs).
BASE_URL=http://localhost:3000

# Auth (M5.5) — sessions & the magic link
# AUTH_SECRET signs magic-link tokens. REQUIRED in production: if unset, a new secret is
# generated each boot and outstanding sign-in links break on every restart.
#   generate with:  openssl rand -hex 32
AUTH_SECRET=
SESSION_SECRET=change-me

# Magic-link email delivery via Resend (https://resend.com). With BOTH set, the sign-in
# link is emailed; without them it is only logged to the server console (real users can't
# receive it). MAIL_FROM must use a domain you verified in Resend (for a quick test,
# onboarding@resend.dev delivers only to your own Resend account).
RESEND_API_KEY=
MAIL_FROM=Amabo <login@yourdomain.com>

# Google OAuth (optional). When both are set, "Continue with Google" appears. Either pair
# of names works (OAUTH_* or CLIENT_*).
GOOGLE_OAUTH_ID=
GOOGLE_OAUTH_SECRET=
# Pin the exact redirect URI registered in the Google console (cures redirect_uri_mismatch).
# GOOGLE_CALLBACK_URL=https://your-api.example.com/auth/callback

# Two-service deploy: the web app's origin (enables CORS + SameSite=None cookies + the
# post-login redirect back to the web app).
# WEB_ORIGIN=https://your-web.example.com

# Web push (optional; used by the API + the notify cron).
#   generate with:  npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:you@yourdomain.com
