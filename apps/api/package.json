    "db:migrate": "drizzle-kit migrate"
  },
  "dependencies": {
    "@amabo/ai": "workspace:*",
    "@amabo/engine": "workspace:*",
    "@amabo/shared": "workspace:*",
    "drizzle-orm": "^0.38.3",
    "express": "^4.21.2",
    "pg": "^8.13.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/pg": "^8.11.10",
    "@types/supertest": "^6.0.2",
    "drizzle-kit": "^0.30.1",
    "supertest": "^7.0.0"
  }
}
